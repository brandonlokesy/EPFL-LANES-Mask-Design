# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.venv/

# Edit-mode outputs — never track these
masks/standard/*EDIT*
masks/standard/*edit*

# Experimental masks — never track
masks/experimental/

# Generated GDS and config outputs — regenerate from source
masks/standard/*.gds
masks/standard/*.json

# Keep the registry
!masks/.registry.json

# VSCode
.vscode/

# OS
.DS_Store
Thumbs.db